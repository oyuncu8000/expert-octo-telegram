    <style>
        :root { --main-bg: #080808; --card-bg: #121212; --accent: #00ff88; }
        body { background: var(--main-bg); color: white; font-family: 'Segoe UI', sans-serif; }
        
        /* Modern Header */
        .top-nav { padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; background: #000; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 1050; }
        .logo { font-weight: 900; color: var(--accent); text-transform: uppercase; letter-spacing: 2px; }
        .open-list-btn { background: var(--accent); color: #000; border: none; padding: 8px 18px; border-radius: 25px; font-weight: bold; }

        /* Video Area */
        .player-box { width: 100%; max-width: 1000px; margin: 15px auto; border-radius: 12px; overflow: hidden; background: #000; box-shadow: 0 0 40px rgba(0,255,136,0.15); }
        .video-js { width: 100% !important; aspect-ratio: 16/9; }

        /* Sidebar & Search */
        .offcanvas { background: var(--card-bg); width: 85% !important; max-width: 380px !important; }
        .search-container { padding: 15px; background: #1a1a1a; position: sticky; top: 0; z-index: 10; border-bottom: 1px solid #333; }
        .search-input { background: #252525; border: 1px solid #444; color: white; border-radius: 10px; padding: 10px; width: 100%; }
        .search-input:focus { background: #2a2a2a; border-color: var(--accent); box-shadow: none; color: white; }

        /* Channel List */
        .channel-item { display: flex; align-items: center; padding: 12px 15px; border-bottom: 1px solid #1a1a1a; cursor: pointer; transition: 0.2s; }
        .channel-item:hover { background: #1a1a1a; }
        .channel-item img { width: 45px; height: 45px; border-radius: 8px; margin-right: 15px; object-fit: contain; background: #000; }
        .channel-item.active { border-left: 5px solid var(--accent); background: #1a1a1a; }
        .channel-item.active .ch-name { color: var(--accent); font-weight: bold; }
    </style>
</head>
