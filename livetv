<script src="https://cdn.jsdelivr.net/npm/@silvermine/videojs-chromecast/dist/silvermine-videojs-chromecast.min.js"></script>
<script src="https://www.gstatic.com/cv/js/sender/v1/cast_sender.js?loadCastFramework=1"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Video Oynatıcı Başlatma
    var player = videojs('iptv-player', {
        techOrder: ['html5', 'chromecast'],
        plugins: {
            chromecast: { addButtonToControlBar: true }
        }
    });

    var sidebar = new bootstrap.Offcanvas(document.getElementById('channelSidebar'));

    // Kanal Oynatma Fonksiyonu
    function playChannel(url, name, el) {
        document.querySelectorAll('.channel-item').forEach(i => i.classList.remove('active'));
        el.classList.add('active');
        
        document.getElementById('playing-title').innerHTML = `<i class="bi bi-broadcast text-danger me-1"></i> ${name}`;

        player.src({ src: url, type: 'application/x-mpegURL' });
        player.play();

        if(window.innerWidth < 992) sidebar.hide();
    }

    // Arama Filtreleme Fonksiyonu
    function filterChannels() {
        let input = document.getElementById('channelSearch').value.toLowerCase();
        let items = document.querySelectorAll('.channel-item');
        
        items.forEach(item => {
            let name = item.innerText.toLowerCase();
            item.style.display = name.includes(input) ? "flex" : "none";
        });
    }

    // İlk kanalı aç
    window.onload = () => {
        const first = document.querySelector('.channel-item');
        if(first) first.click();
    };
</script>

